# Copy this file to .env, replace the secret placeholders, then run:
#   docker compose up --build --wait
# The router is available at http://localhost:${ROUTER_PORT:-8080}.
# Downloader and builder have no host ports and are reachable only by service name.

# Shared by all services. Generate a long random value; do not commit it.
INTERNAL_SERVICE_TOKEN=replace-with-a-random-internal-token
# Router only. Use the secret configured for GitHub webhook delivery.
WEBHOOK_SECRET=
# Downloader only. Optional for local use, but avoids GitHub API rate limits.
GITHUB_TOKEN=

# Host-facing router port and internal service URLs.
ROUTER_PORT=8080
DOWNLOADER_URL=http://downloader:8080
BUILDER_URL=http://builder:8080

# Ephemeral cache roots are fixed by compose.yaml and owned by UID/GID 1000.
# They are separate tmpfs mounts and are discarded when containers stop.
DOWNLOADER_CACHE_ROOT=/app/downloader-cache
BUILDER_CACHE_ROOT=/app/tmp

# Queue limits (jobs per process).
DOWNLOADER_MAX_QUEUE_SIZE=2
BUILDER_MAX_QUEUE_SIZE=2

# Timeouts and cleanup intervals/lifetimes are milliseconds.
PUBLIC_DOWNLOADER_TIMEOUT=15000
PUBLIC_BUILDER_TIMEOUT=180000
# The v13 detection HEAD request is intentionally fixed at 5000ms.
BUILDER_DOWNLOADER_TIMEOUT=120000
DOWNLOADER_CLEAN_INTERVAL=120000
BUILDER_CLEAN_INTERVAL=120000
DOWNLOADER_CACHE_LIFETIME=604800000
BUILDER_CACHE_LIFETIME=604800000

# Downloader upstream and in-memory GitHub lookup cache TTLs (milliseconds).
DOWNLOADER_SOURCE_URL=https://raw.githubusercontent.com/highcharts/highcharts/
GITHUB_LOOKUP_CACHE_TTL=60000
GITHUB_LOOKUP_NEGATIVE_CACHE_TTL=10000

# Stop and remove the local stack with: docker compose down
